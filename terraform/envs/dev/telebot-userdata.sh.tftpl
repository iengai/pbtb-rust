#!/bin/bash
set -euxo pipefail

#####################################################################
# Part 1: NAT setup
# (injected verbatim from modules/network/nat-userdata-al2023.sh so the
#  iptables/MASQUERADE logic stays single-sourced)
#####################################################################
${nat_setup_script}

#####################################################################
# Part 2: Host prep — swap, Docker, AWS CLI
#####################################################################

# Small swap file as cheap OOM insurance on a memory-constrained box (idempotent).
# The bot container itself is hard-capped below; this cushions host processes
# (dockerd / sshd) so a transient spike never wedges the NAT host.
if [ ! -f /swapfile ]; then
  dd if=/dev/zero of=/swapfile bs=1M count=512
  chmod 600 /swapfile
  mkswap /swapfile
  swapon /swapfile
  echo '/swapfile none swap sw 0 0' >> /etc/fstab
fi

# Retry helper for transient dnf/network failures during first boot.
retry() { for _i in 1 2 3 4 5; do "$@" && return 0; echo "retry: $*"; sleep 10; done; return 1; }

# Relax errexit for the package-install block so a transient failure cannot abort
# the script BEFORE the self-healing telebot systemd unit (Part 3) is installed.
set +e
retry dnf install -y docker
systemctl enable --now docker

# Ensure AWS CLI v2 is available (used for ECR login + SSM token fetch)
if ! command -v aws >/dev/null 2>&1; then
  retry dnf install -y awscli-2 || {
    retry dnf install -y unzip
    retry curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-aarch64.zip" -o /tmp/awscliv2.zip
    unzip -q /tmp/awscliv2.zip -d /tmp && /tmp/aws/install
  }
fi
set -e

#####################################################################
# Part 3: Telebot launch script + systemd service
#
# This bootstrap is APP-CONFIG-FREE: run-telebot.sh reads ALL config from
# /etc/telebot/telebot.env, which the telebot-deploy pipeline writes onto this
# host (and refreshes on every deploy). Until that first deploy lands the file,
# run-telebot.sh exits non-zero and systemd (Restart=always) retries every 30s.
# The Telegram token is never written to disk — it is fetched from SSM at runtime.
#####################################################################
cat >/usr/local/bin/run-telebot.sh <<'SCRIPT'
#!/bin/bash
set -euo pipefail

ENV_FILE=/etc/telebot/telebot.env
if [ ! -f "$ENV_FILE" ]; then
  echo "run-telebot: $ENV_FILE not present yet — waiting for first telebot-deploy" >&2
  exit 1
fi

# Read the host-only TELEBOT_* values WITHOUT sourcing/eval, so a value with
# shell metacharacters can never be expanded or executed on this egress host.
val() { grep -m1 "^$1=" "$ENV_FILE" | cut -d= -f2-; }
TELEBOT_REGION="$(val TELEBOT_REGION)"
TELEBOT_ECR_REGISTRY="$(val TELEBOT_ECR_REGISTRY)"
TELEBOT_IMAGE="$(val TELEBOT_IMAGE)"
TELEBOT_TOKEN_PARAM="$(val TELEBOT_TOKEN_PARAM)"
TELEBOT_MEMORY="$(val TELEBOT_MEMORY)"

# Container env = APP__*/RUST_LOG only (exclude the TELEBOT_* host-orchestration
# vars). Written to tmpfs and refreshed each start; docker parses it literally.
install -d -m 700 /run/telebot
grep -E '^(APP__|RUST_LOG=)' "$ENV_FILE" > /run/telebot/container.env

# Token is fetched at runtime so it is never persisted to disk / the env file.
TELOXIDE_TOKEN="$(aws ssm get-parameter --name "$TELEBOT_TOKEN_PARAM" --with-decryption --region "$TELEBOT_REGION" --query 'Parameter.Value' --output text)"

aws ecr get-login-password --region "$TELEBOT_REGION" | docker login --username AWS --password-stdin "$TELEBOT_ECR_REGISTRY"
docker pull "$TELEBOT_IMAGE"
docker rm -f telebot >/dev/null 2>&1 || true

exec docker run --rm --name telebot \
  --memory="$TELEBOT_MEMORY" --memory-swap="$TELEBOT_MEMORY" \
  --log-driver=json-file --log-opt max-size=10m --log-opt max-file=3 \
  --env-file /run/telebot/container.env \
  -e TELOXIDE_TOKEN="$TELOXIDE_TOKEN" \
  "$TELEBOT_IMAGE"
SCRIPT
chmod +x /usr/local/bin/run-telebot.sh

cat >/etc/systemd/system/telebot.service <<'UNIT'
[Unit]
Description=pbtb-rust telebot container
After=docker.service network-online.target
Wants=docker.service network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/run-telebot.sh
Restart=always
RestartSec=30

[Install]
WantedBy=multi-user.target
UNIT

systemctl daemon-reload
systemctl enable --now telebot.service
